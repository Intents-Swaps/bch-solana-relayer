# ==========================================
# BCH Configuration (Chipnet Testnet)
# ==========================================
# Must be a valid unified WIF format for Chipnet (starts with c)
# This wallet will be used by the Relayer to lock BCH into the HTLC
BCH_PRIVATE_KEY_WIF=c...YOUR_TESTNET_WIF_HERE...
# Or use a local wallet.json file path
BCH_WALLET_PATH=

# ==========================================
# Solana Configuration (Devnet)
# ==========================================
# We recommend using a Helius RPC for stability during testing
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
# Must be a Base58 encoded private key string (export from Phantom wallet)
SOLANA_PRIVATE_KEY=5...YOUR_BASE58_PRIVATE_KEY...

# ==========================================
# Movement / Aptos Configuration (Testnet)
# ==========================================
MOVEMENT_RPC_URL=https://testnet.movementnetwork.xyz/v1
# Must be a 64-character hex string (starts with 0x)
MOVEMENT_PRIVATE_KEY=0x...YOUR_HEX_PRIVATE_KEY...
# The deployed Movement HTLC module address on testnet
MOVEMENT_HTLC_ADDRESS=0x485ca1c12b5dfa01c282b9c7ef09fdfebbf877ed729bf999ce61a8ec5c5e69bd
# Server
PORT=3004

# Timelocks (seconds)
SOURCE_TIMELOCK=7200
DEST_TIMELOCK=3600

# Polling
POLL_INTERVAL_MS=10000
